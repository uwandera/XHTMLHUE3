Create DATABASE Fatek;

USE Fatek;

-- Tabela PESSOA
CREATE TABLE pessoa (
    id_pessoa INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(20),
    cpf VARCHAR(15),
    rg VARCHAR(20),
    endereco VARCHAR(100),
    bairro VARCHAR(50),
    cidade VARCHAR(50),
    uf VARCHAR(2),
    cep VARCHAR(10),
    email VARCHAR(30),
    telefone VARCHAR(15)
);

-- Tabela CLIENTE (Relacionada com PESSOA)
CREATE TABLE cliente (
    idpessoa INT PRIMARY KEY,
    codigo_cliente VARCHAR(10),
    FOREIGN KEY (idpessoa) REFERENCES pessoa(idpessoa)
);

-- Tabela FUNCIONARIO (Relacionada com PESSOA)
CREATE TABLE funcionario (
    idpessoa INT PRIMARY KEY,
    salario DECIMAL(7,2),
    acesso VARCHAR(15),
    login VARCHAR(15),
    password VARCHAR(25),
    status VARCHAR(25),
    FOREIGN KEY (idpessoa) REFERENCES pessoa(idpessoa)
);

-- Tabela SUITE
CREATE TABLE suite (
    idsuites INT PRIMARY KEY AUTO_INCREMENT,
    tipoSuites VARCHAR(20),
    numero VARCHAR(4),
    piso VARCHAR(2),
    descricao VARCHAR(255),
    precoDiario DECIMAL(7,2),
    status VARCHAR(15)
);

-- Tabela RESERVA (Relacionada com CLIENTE, SUITE e FUNCIONARIO)
CREATE TABLE reserva (
    idreserva INT PRIMARY KEY AUTO_INCREMENT,
    idcliente INT,
    idsuites INT,
    idfuncionario INT,
    data_reserva DATE,
    data_entrada DATE,
    data_saida DATE,
    custo_hospedagem DECIMAL(7,2),
    status VARCHAR(15),
    FOREIGN KEY (idcliente) REFERENCES cliente(idpessoa),
    FOREIGN KEY (idsuites) REFERENCES suite(idsuites),
    FOREIGN KEY (idfuncionario) REFERENCES funcionario(idpessoa)
);

-- Tabela PRODUTO
CREATE TABLE produto (
    idproduto INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(45),
    descricao VARCHAR(255),
    quantidade VARCHAR(20),
    preco DECIMAL(7,2),
    status VARCHAR(15)
);

-- Tabela CONSUMO (Relacionada com RESERVA e PRODUTO)
CREATE TABLE consumo (
    idconsumo INT PRIMARY KEY AUTO_INCREMENT,
    idreserva INT,
    idproduto INT,
    quantidade DECIMAL(7,2),
    preco DECIMAL(7,2),
    status VARCHAR(15),
    FOREIGN KEY (idreserva) REFERENCES reserva(idreserva),
    FOREIGN KEY (idproduto) REFERENCES produto(idproduto)
);

-- Tabela PAGAMENTO (Relacionada com RESERVA)
CREATE TABLE pagamento (
    idpagamento INT PRIMARY KEY AUTO_INCREMENT,
    idreserva INT,
    tipo_comprovante VARCHAR(20),
    num_comprovante VARCHAR(20),
    total_pagamento DECIMAL(7,2),
    data_emissao DATE,
    data_pagamento DATE,
    FOREIGN KEY (idreserva) REFERENCES reserva(idreserva)
);

